---
/**
 * BaseLayout — the only top-level wrapper. Every page reuses it.
 *
 * Responsibilities:
 *  - <head> meta tags (description, OG, Twitter, canonical, hreflang)
 *  - Structured data (JSON-LD) — caller passes optional `jsonLd` prop
 *  - Theme + colour-scheme bootstrap (prevents FOUC by reading localStorage
 *    BEFORE the body renders)
 *  - Slots for header / page content / footer
 */
import '../styles/global.css';
import { strings, SITE_URL, type Lang } from '../i18n/strings';
import CookieBanner from '../components/CookieBanner.astro';
import { STORE_LINKS, SOCIAL } from '../lib/constants';
import { CREATOR_NAME, buildIdentityGraph } from '../lib/seo';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StoreBadge from '../components/StoreBadge.astro';

interface Props {
  lang?: Lang;
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  /** Optional alternate language path so we can emit hreflang. */
  altLangPath?: string;
  /** Optional JSON-LD payload(s) for schema.org markup. */
  jsonLd?: object | object[];
  /** Explicit robots directives. Defaults to full snippet eligibility. */
  robots?: string;
  /** Accessible alt text for the social image. */
  ogImageAlt?: string;
  /** Hides the global app-download CTA strip when set (e.g. on legal pages). */
  hideDownloadStrip?: boolean;
}

const {
  lang = 'hu',
  title,
  description,
  canonical,
  ogImage = '/og-default.png',
  altLangPath,
  jsonLd,
  robots = 'index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1',
  ogImageAlt,
  hideDownloadStrip = false,
} = Astro.props;

const t = strings[lang];
const metaDescription = description ?? t.description;
const url = canonical ?? new URL(Astro.url.pathname, SITE_URL).toString();
const ogImageUrl = new URL(ogImage, SITE_URL).toString();
const imageAlt = ogImageAlt ?? `${t.brand} — modern magyar névnap-naptár`;
const defaultLanguageUrl = altLangPath ? new URL(altLangPath, SITE_URL).toString() : null;

const jsonLdEntries = jsonLd
  ? [buildIdentityGraph(lang), ...(Array.isArray(jsonLd) ? jsonLd : [jsonLd])]
  : [buildIdentityGraph(lang)];
---

<!doctype html>
<html lang={lang === 'en' ? 'en' : 'hu'} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fbfaff" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0b0c18" />

    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <meta name="bingbot" content={robots} />
    <meta name="author" content={CREATOR_NAME} />
    <meta name="publisher" content={t.brand} />
    <meta name="application-name" content={t.brand} />
    <meta name="apple-mobile-web-app-title" content={t.brand} />
    {import.meta.env.PROD && <meta name="google-adsense-account" content="ca-pub-5975990857512539" />}
    <meta name="format-detection" content="telephone=no" />
    <link rel="canonical" href={url} />
    <link rel="alternate" type="text/plain" href={new URL('/llms.txt', SITE_URL).toString()} title="LLM summary" />
    <link rel="alternate" type="text/plain" href={new URL('/llms-full.txt', SITE_URL).toString()} title="LLM full context" />
    <link rel="me" href={SOCIAL.instagram} />
    <link rel="me" href={SOCIAL.tiktok} />

    <!-- hreflang alternates -->
    {altLangPath && lang === 'hu' && (
      <link rel="alternate" hreflang="en" href={new URL(`/en${altLangPath}`, SITE_URL).toString()} />
    )}
    {altLangPath && lang === 'en' && (
      <link rel="alternate" hreflang="hu" href={new URL(altLangPath, SITE_URL).toString()} />
    )}
    {defaultLanguageUrl && <link rel="alternate" hreflang="x-default" href={defaultLanguageUrl} />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'hu_HU'} />
    {altLangPath && <meta property="og:locale:alternate" content={lang === 'en' ? 'hu_HU' : 'en_US'} />}
    <meta property="og:site_name" content={t.brand} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <!-- Favicon / icon -->
    <link rel="icon" type="image/png" href="/icons/app-icon.png" />
    <link rel="apple-touch-icon" href="/icons/app-icon.png" />

    <!-- Fonts: Geist (display) + Inter (body). Both via Google Fonts with preconnect. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" />

    <!-- Theme bootstrap (no FOUC) -->
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem('nevnap-theme');
          const theme = saved ?? 'dark';
          if (theme === 'dark') document.documentElement.classList.add('dark');
        } catch (_) {}
      })();
    </script>

    {jsonLdEntries.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}

  <!-- Google Analytics GA4 — csak prod + felhasználói consent után -->
  {import.meta.env.PROD && (
    <>
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-CZKZV7GE2N" is:inline></script>
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        // GDPR Consent Mode v2 — alapból mindent denied
        gtag('consent', 'default', {
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
          analytics_storage: 'denied',
          functionality_storage: 'granted',
          security_storage: 'granted',
          wait_for_update: 500
        });
        gtag('config', 'G-CZKZV7GE2N', {
          anonymize_ip: true,
          cookie_flags: 'SameSite=None;Secure',
        });
        // Read existing consent & update
        function applyConsent(c) {
          if (!c) return;
          gtag('consent', 'update', {
            analytics_storage: c.analytics ? 'granted' : 'denied',
            ad_storage: c.marketing ? 'granted' : 'denied',
            ad_user_data: c.marketing ? 'granted' : 'denied',
            ad_personalization: c.marketing ? 'granted' : 'denied',
          });
        }
        try { applyConsent(JSON.parse(localStorage.getItem('nevnap-consent'))); } catch (e) {}
        window.addEventListener('consent-updated', function (e) { applyConsent(e.detail); });
      </script>
      <script
        async
        is:inline
        src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5975990857512539"
        crossorigin="anonymous"
      ></script>
    </>
  )}

    <!-- Cookie consent korai check — anti-FOUC, MUST be in <head> before render -->
    <script is:inline>
      (function(){try{var c=localStorage.getItem('nevnap-consent');document.documentElement.dataset.cookieConsent=c?'given':'pending';}catch(e){document.documentElement.dataset.cookieConsent='pending';}})();
    </script>
  </head>
  <body class="font-body">
    <a href="#main" class="skip-link">
      {lang === 'hu' ? 'Ugrás a fő tartalomhoz' : 'Skip to main content'}
    </a>

    <Header lang={lang} altLangPath={altLangPath} />

    <main id="main" class="relative" tabindex="-1">
      <slot />
    </main>

    {!hideDownloadStrip && (
      <section
        aria-labelledby="download-heading"
        class="border-t border-zinc-200/60 dark:border-white/5 mt-24 py-16"
      >
        <div class="container mx-auto px-6 text-center">
          <h2 id="download-heading" class="text-3xl md:text-4xl font-extrabold tracking-tight">
            {lang === 'hu'
              ? 'Töltsd le a NévnapTárX appot ingyen'
              : 'Download NévnapTárX free'}
          </h2>
          <p class="mt-3 text-zinc-600 dark:text-zinc-300 max-w-xl mx-auto">
            {lang === 'hu'
              ? '1500 név, napi értesítés, név-jelentések — egy modern app a zsebedben.'
              : '1500 names, daily reminders, name meanings — a modern app in your pocket.'}
          </p>
          <div class="mt-8 flex items-center justify-center gap-4 flex-wrap" role="group" aria-label={lang === 'hu' ? 'Letöltési linkek' : 'Download links'}>
            <StoreBadge store="apple" href={STORE_LINKS.appStore} lang={lang} />
            <StoreBadge store="google" href={STORE_LINKS.playStore} lang={lang} />
          </div>
        </div>
      </section>
    )}

    <Footer lang={lang} />
      <CookieBanner lang={lang} />
  </body>
</html>
