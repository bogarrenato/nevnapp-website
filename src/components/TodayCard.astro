---
/**
 * Large featured card for today's nameday. Sits below the hero.
 * Uses the same coral→pink gradient as the Flutter hero card so the
 * brand identity is consistent across surfaces.
 */
import { strings, localizedPath, interpolate, type Lang } from '../i18n/strings';
import { getBudapestCalendarDate, getTodayEntry, getMeaning } from '../lib/names';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = strings[lang];
const today = getBudapestCalendarDate();
const entry = getTodayEntry();
const primary = entry?.primary ?? [];
const secondary = entry?.secondary ?? [];
const firstMeaning = primary.length ? getMeaning(primary[0]) : null;

const todayLabel = lang === 'hu'
  ? `${t.months[today.month - 1]} ${today.day}.`
  : `${t.months[today.month - 1]} ${today.day}`;
---

<section class="container mx-auto px-6 -mt-8" aria-labelledby="today-card-heading">
  <article
    class="relative rounded-3xl overflow-hidden p-8 md:p-12 text-white shadow-2xl shadow-coral-500/20"
    style="background: linear-gradient(135deg, var(--color-coral-500), var(--color-coral-600), var(--color-violet-500));"
  >
    <div aria-hidden="true" class="absolute -top-10 -right-10 w-48 h-48 rounded-full bg-white/15"></div>
    <div aria-hidden="true" class="absolute -bottom-12 -left-8 w-40 h-40 rounded-full bg-white/8"></div>

    <div class="relative">
      <p class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/25 backdrop-blur text-xs font-semibold tracking-wide uppercase">
        <span>{t.today.heading}</span>
        <span aria-hidden="true">—</span>
        <time datetime={today.iso}>{todayLabel}</time>
      </p>

      {primary.length ? (
        <h2 id="today-card-heading" class="mt-5 text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.0]">
          {primary.join(' és ')}
        </h2>
      ) : (
        <h2 id="today-card-heading" class="mt-5 text-3xl md:text-4xl font-bold">{t.today.noNameday}</h2>
      )}

      {primary.length > 0 && (
        <ul class="mt-6 flex flex-wrap items-center gap-2 list-none">
          {primary.map((name) => (
            <li>
              <a
                href={localizedPath(lang, `/name/${encodeURIComponent(name)}`)}
                class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-white/20 hover:bg-white/30 backdrop-blur text-sm font-semibold transition"
                aria-label={lang === 'hu' ? `${name} névnap részletei` : `Details for ${name}`}
              >
                {name}
                <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" aria-hidden="true" focusable="false">
                  <path d="M5 12h14M13 6l6 6-6 6"/>
                </svg>
              </a>
            </li>
          ))}
        </ul>
      )}

      {firstMeaning && (
        <div class="mt-8 max-w-2xl">
          <p class="text-xs uppercase tracking-widest font-semibold opacity-80 mb-2">
            {interpolate(t.namePage.meaningHeading, { name: primary[0] })}
          </p>
          <p class="text-base md:text-lg opacity-95 leading-relaxed">{firstMeaning}</p>
        </div>
      )}

      {secondary.length > 0 && (
        <div class="mt-8 pt-6 border-t border-white/20">
          <h3 class="text-xs uppercase tracking-widest font-semibold opacity-80 mb-3">{t.today.secondaryHeading}</h3>
          <ul class="flex flex-wrap gap-2 list-none">
            {secondary.map((name) => (
              <li>
                <a
                  href={localizedPath(lang, `/name/${encodeURIComponent(name)}`)}
                  class="px-3 py-1 rounded-full text-sm bg-white/10 hover:bg-white/20 transition"
                >
                  {name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </article>
</section>
