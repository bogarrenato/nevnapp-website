---
/**
 * Dynamic route — one page per calendar day (MM-DD).
 * URL: /day/05-25 → "Május 25. névnap"
 * 366 pages total, each one targets "{month} {day} névnap" queries.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { strings } from '../../i18n/strings';
import { getEntryByDate } from '../../lib/names';
import {
  SEO_IDS,
  buildBreadcrumbSchema,
  buildFaqSchema,
  buildItemListSchema,
  buildWebPageSchema,
} from '../../lib/seo';

// NOTE: arrow functions declared at the top of the frontmatter are NOT
// visible inside `getStaticPaths` — that function runs in a separate
// module context. Helpers it needs must be inlined or defined within.
export function getStaticPaths() {
  const pad = (n: number) => String(n).padStart(2, '0');
  const paths = [];
  for (let month = 1; month <= 12; month++) {
    const daysInMonth = new Date(2024, month, 0).getDate();
    for (let day = 1; day <= daysInMonth; day++) {
      paths.push({
        params: { date: `${pad(month)}-${pad(day)}` },
        props: { month, day },
      });
    }
  }
  return paths;
}

const monthsPadded = (m: number) => String(m).padStart(2, '0');

const { month, day } = Astro.props as { month: number; day: number };
const t = strings.hu;
const entry = getEntryByDate(month, day);
const dateLabel = `${t.months[month - 1]} ${day}.`;
const primary = entry?.primary ?? [];
const secondary = entry?.secondary ?? [];
const allNamesForDay = [...primary, ...secondary];
const pagePath = `/day/${monthsPadded(month)}-${monthsPadded(day)}`;

const title = primary.length
  ? `${dateLabel} névnap: ${primary.join(', ')} | ${t.brand}`
  : `${dateLabel} névnap | ${t.brand}`;

const description = primary.length
  ? `${dateLabel} ${primary.join(' és ')} névnapja. Jelentés, eredet, köszöntők és napi értesítések a NévnapTárX appal.`
  : `${dateLabel} névnap a magyar naptár szerint. Töltsd le a NévnapTárX appot iOS-re és Androidra.`;

const directAnswer = primary.length
  ? `${dateLabel} névnapja: ${primary.join(' és ')}.`
  : `${dateLabel} napján nincs kiemelt névnap az adatbázisban.`;

const secondaryAnswer = secondary.length
  ? `További nevek ezen a napon: ${secondary.join(', ')}.`
  : 'Ezen a napon nincs további név felsorolva.';

const faqEntries = [
  {
    q: `Kinek van névnapja ${dateLabel.toLowerCase()}?`,
    a: `${directAnswer} ${secondaryAnswer}`,
  },
  {
    q: `Hol találok részleteket a ${dateLabel.toLowerCase()} névnapos nevekről?`,
    a: allNamesForDay.length
      ? `A névjelentések és köszöntők a névoldalakon érhetők el: ${allNamesForDay.join(', ')}.`
      : 'A teljes magyar névnap-naptár a /calendar oldalon böngészhető.',
  },
];

const jsonLd = [
  buildWebPageSchema({
    path: pagePath,
    name: title,
    description,
    about: { '@id': SEO_IDS.namedayDataset },
  }),
  buildBreadcrumbSchema([
    { name: t.brand, path: '/' },
    { name: t.nav.calendar, path: '/calendar' },
    { name: dateLabel, path: pagePath },
  ]),
  buildFaqSchema(faqEntries),
  allNamesForDay.length
    ? buildItemListSchema({
        name: `${dateLabel} névnapos nevek`,
        path: pagePath,
        items: allNamesForDay.map((name) => ({
          name,
          path: `/name/${encodeURIComponent(name)}`,
        })),
      })
    : null,
].filter(Boolean) as object[];
---

<BaseLayout
  lang="hu"
  title={title}
  description={description}
  jsonLd={jsonLd}
>
  <article class="container mx-auto px-6 max-w-3xl pt-12 md:pt-16">
    <nav class="text-sm text-zinc-500" aria-label={t.dayPage.breadcrumbAria}>
      <ol class="flex items-center gap-2 list-none">
        <li><a href="/" class="hover:text-primary-500">{t.brand}</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/calendar" class="hover:text-primary-500">{t.nav.calendar}</a></li>
        <li aria-hidden="true">›</li>
        <li aria-current="page" class="text-zinc-700 dark:text-zinc-300">{dateLabel}</li>
      </ol>
    </nav>

    <header class="mt-6">
      <p class="text-sm uppercase tracking-widest font-semibold text-primary-600 dark:text-primary-400">{t.dayPage.eyebrow}</p>
      <h1 class="mt-2 text-5xl md:text-6xl font-extrabold tracking-tight">
        <span class="gradient-text">
          <time datetime={`--${monthsPadded(month)}-${monthsPadded(day)}`}>{dateLabel}</time>
        </span> névnap
      </h1>
    </header>

    <section class="mt-8 rounded-2xl border border-primary-500/20 bg-primary-50/70 dark:bg-primary-500/10 p-5" aria-labelledby="quick-answer-heading">
      <h2 id="quick-answer-heading" class="text-sm uppercase tracking-widest font-semibold text-primary-700 dark:text-primary-300">Rövid válasz</h2>
      <p class="mt-3 text-lg font-semibold text-zinc-900 dark:text-zinc-100">{directAnswer}</p>
      <p class="mt-2 text-zinc-700 dark:text-zinc-300 leading-relaxed">{secondaryAnswer}</p>
    </section>

    {primary.length ? (
      <section
        class="mt-10 rounded-3xl p-8 md:p-12 text-white shadow-2xl shadow-primary-500/20"
        style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-violet-500));"
        aria-labelledby="primary-heading"
      >
        <p class="text-xs uppercase tracking-widest opacity-80">{t.dayPage.primary}</p>
        <h2 id="primary-heading" class="mt-3 text-4xl md:text-5xl font-extrabold">{primary.join(' és ')}</h2>
        <ul class="mt-6 flex flex-wrap gap-2 list-none">
          {primary.map((name) => (
            <li>
              <a
                href={`/name/${encodeURIComponent(name)}`}
                class="px-4 py-1.5 rounded-full bg-white/25 hover:bg-white/35 transition font-semibold text-sm backdrop-blur inline-flex items-center gap-1"
                aria-label={`${name} név részletei`}
              >
                {name}
                <span aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ) : (
      <section class="mt-10 glass rounded-3xl p-8" aria-label={t.dayPage.noNameday}>
        <p class="text-zinc-600 dark:text-zinc-400">{t.dayPage.noNameday}</p>
      </section>
    )}

    {secondary.length > 0 && (
      <section class="mt-8 glass rounded-3xl p-6 md:p-8" aria-labelledby="secondary-heading">
        <h3 id="secondary-heading" class="text-xs uppercase tracking-widest font-semibold text-zinc-500 dark:text-zinc-400 mb-4">
          {t.dayPage.secondary}
        </h3>
        <ul class="flex flex-wrap gap-2 list-none">
          {secondary.map((n) => (
            <li>
              <a href={`/name/${encodeURIComponent(n)}`} class="px-3 py-1.5 rounded-full bg-zinc-100 dark:bg-white/10 hover:bg-primary-100 dark:hover:bg-primary-500/20 transition text-sm">
                {n}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="mt-12" aria-labelledby="day-faq-heading">
      <h2 id="day-faq-heading" class="text-2xl md:text-3xl font-extrabold tracking-tight">
        Gyakori kérdések — {dateLabel} névnap
      </h2>
      <dl class="mt-6 space-y-4">
        {faqEntries.map((entry) => (
          <div class="rounded-2xl border border-zinc-200 dark:border-white/10 p-5">
            <dt class="font-bold text-zinc-900 dark:text-zinc-100">{entry.q}</dt>
            <dd class="mt-2 text-zinc-700 dark:text-zinc-300 leading-relaxed">{entry.a}</dd>
          </div>
        ))}
      </dl>
    </section>
  </article>
</BaseLayout>
