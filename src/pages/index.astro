---
/**
 * Hungarian landing page — the SEO crown jewel.
 *
 * Targets: "mai névnap", "magyar névnaptár", "név jelentése" head queries.
 * Inlines today's nameday + meaning so it ranks even before any clicks.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TodayCard from '../components/TodayCard.astro';
import UpcomingStrip from '../components/UpcomingStrip.astro';
import { strings } from '../i18n/strings';
import { getAllNames, getBudapestCalendarDate, getTodayEntry, getMeaning } from '../lib/names';
import {
  SEO_IDS,
  buildFaqSchema,
  buildNamedayDatasetSchema,
  buildWebPageSchema,
} from '../lib/seo';

const t = strings.hu;
const today = getBudapestCalendarDate();
const entry = getTodayEntry();
const primaryNames = entry?.primary ?? [];
const allNames = getAllNames();

const pageTitle = primaryNames.length
  ? `Mai névnap: ${primaryNames.join(' és ')} — ${t.months[today.month - 1]} ${today.day}. | ${t.brand}`
  : `Mai névnap — ${t.months[today.month - 1]} ${today.day}. | ${t.brand}`;

const pageDescription = primaryNames.length
  ? `Ma ${primaryNames.join(' és ')} névnapja van. Jelentés, eredet, köszöntők és napi névnap értesítések a NévnapTárX modern névnap-naptár appal.`
  : t.description;

const todayAnswer = primaryNames.length
  ? `Ma, ${t.months[today.month - 1]} ${today.day}-án ${primaryNames.join(' és ')} névnapja van a magyar névnap-naptár szerint.`
  : `Ma, ${t.months[today.month - 1]} ${today.day}-án nincs kiemelt névnap az adatbázisban.`;

const faqEntries = [
  {
    q: 'Kinek van ma névnapja?',
    a: todayAnswer,
  },
  {
    q: 'Hány magyar név szerepel a NévnapTárX adatbázisában?',
    a: `A NévnapTárX adatbázisa ${allNames.length} magyar keresztnevet tartalmaz névnapokkal és sok esetben névjelentéssel.`,
  },
  {
    q: 'Hol található a teljes magyar névnap-naptár?',
    a: 'A teljes, napokra bontott magyar névnap-naptár a /calendar oldalon érhető el, a név szerinti kereséshez pedig a /names oldal használható.',
  },
];

const jsonLd = [
  buildWebPageSchema({
    path: '/',
    name: pageTitle,
    description: pageDescription,
    about: [
      { '@id': SEO_IDS.namedayDataset },
      { '@id': SEO_IDS.app },
    ],
  }),
  buildNamedayDatasetSchema(allNames.length),
  buildFaqSchema(faqEntries),
].filter(Boolean) as object[];
---

<BaseLayout
  lang="hu"
  title={pageTitle}
  description={pageDescription}
  altLangPath="/"
  jsonLd={jsonLd}
>
  <Hero lang="hu" />
  <TodayCard lang="hu" />
  <UpcomingStrip lang="hu" />

  <section class="container mx-auto px-6 mt-20 max-w-4xl" aria-labelledby="direct-answers-heading">
    <p class="text-sm uppercase tracking-widest font-semibold text-primary-600 dark:text-primary-400">Rövid válaszok</p>
    <h2 id="direct-answers-heading" class="mt-2 text-3xl md:text-4xl font-extrabold tracking-tight">
      Mai névnap és magyar névnap-adatbázis
    </h2>
    <dl class="mt-6 grid gap-4 md:grid-cols-3">
      {faqEntries.map((entry) => (
        <div class="rounded-2xl border border-zinc-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-5">
          <dt class="font-bold text-zinc-900 dark:text-zinc-100">{entry.q}</dt>
          <dd class="mt-2 text-sm leading-relaxed text-zinc-700 dark:text-zinc-300">{entry.a}</dd>
        </div>
      ))}
    </dl>
    {primaryNames.length > 0 && (
      <p class="mt-5 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
        {primaryNames.map((name) => `${name}: ${getMeaning(name) ?? 'névjelentés hamarosan.'}`).join(' ')}
      </p>
    )}
    <p class="mt-3 text-sm text-zinc-500 dark:text-zinc-500">
      Adatforrás: a NévnapTárX szerkesztett magyar névnap- és névjelentés adatbázisa. Utolsó napi oldalfrissítés: {today.iso}.
    </p>
  </section>

  <!-- SEO content block — visible explanatory copy for users and crawlers -->
  <section class="container mx-auto px-6 mt-24 max-w-3xl">
    <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight">{t.homeSeo.heading}</h2>
    <div class="mt-6 space-y-4 text-zinc-700 dark:text-zinc-300 leading-relaxed">
      <p>{t.homeSeo.p1}</p>
      <p>{t.homeSeo.p2}</p>
    </div>

    <div class="mt-12 grid sm:grid-cols-3 gap-4">
      {[
        { label: '1500+', text: t.homeSeo.statNames },
        { label: '366', text: t.homeSeo.statDays },
        { label: '0 Ft', text: t.homeSeo.statFree },
      ].map((stat) => (
        <div class="glass rounded-2xl p-5 text-center">
          <p class="text-3xl font-extrabold gradient-text">{stat.label}</p>
          <p class="text-sm text-zinc-600 dark:text-zinc-400 mt-1">{stat.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Ko-fi Support Section -->
  <section class="container mx-auto px-6 mt-20 max-w-4xl" aria-labelledby="support-heading">
    <div class="relative overflow-hidden rounded-3xl p-8 md:p-12 bg-gradient-to-br from-amber-500/10 via-orange-400/5 to-yellow-400/10 border border-amber-400/20">
      <!-- Decorative ambient blobs -->
      <div aria-hidden="true" class="absolute -top-16 -right-16 size-56 rounded-full bg-amber-400/15 blur-3xl pointer-events-none"></div>
      <div aria-hidden="true" class="absolute -bottom-12 -left-12 size-40 rounded-full bg-orange-400/10 blur-2xl pointer-events-none"></div>

      <div class="relative flex flex-col md:flex-row items-start md:items-center gap-8">
        <!-- Icon -->
        <div aria-hidden="true" class="shrink-0 size-20 rounded-2xl bg-amber-400/15 border border-amber-400/30 grid place-items-center text-4xl shadow-lg shadow-amber-400/10">
          ☕
        </div>

        <!-- Text -->
        <div class="flex-1 min-w-0">
          <p class="text-xs uppercase tracking-widest font-semibold text-amber-500 dark:text-amber-400">{t.support.eyebrow}</p>
          <h2 id="support-heading" class="mt-2 text-2xl md:text-3xl font-extrabold tracking-tight">
            {t.support.heading}
          </h2>
          <p class="mt-3 text-zinc-600 dark:text-zinc-400 leading-relaxed max-w-xl">
            {t.support.body}
          </p>
        </div>

        <!-- CTA -->
        <div class="shrink-0 flex flex-col items-start md:items-end gap-2">
          <a
            href="https://ko-fi.com/bogarrenato"
            target="_blank"
            rel="noopener noreferrer"
            class="group relative inline-flex items-center gap-2.5 px-7 py-3.5 rounded-full bg-amber-400 hover:bg-amber-300 active:bg-amber-500 text-zinc-900 font-extrabold text-sm shadow-xl shadow-amber-400/30 hover:shadow-amber-400/50 hover:scale-105 transition-all"
          >
            <!-- Animated ring behind button -->
            <span aria-hidden="true" class="pointer-events-none absolute -inset-1 rounded-full bg-amber-400/30 animate-ping opacity-60 group-hover:opacity-80"></span>
            <span aria-hidden="true" class="text-lg">☕</span>
            {t.support.cta}
            <svg class="size-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true" focusable="false">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </a>
          <p class="text-xs text-zinc-500 dark:text-zinc-500 pl-1">{t.support.subtext}</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
