---
import BaseLayout from '../layouts/BaseLayout.astro';
import { strings } from '../i18n/strings';
const t = strings.hu;
---
<BaseLayout lang="hu" title={`Kapcsolat | ${t.brand}`} description="Lépj kapcsolatba a NévnapTárX fejlesztőjével." altLangPath="/contact">
  <article class="container mx-auto px-6 max-w-3xl pt-12 md:pt-16">
    <nav class="text-sm text-zinc-500" aria-label="Morzsamenü">
      <ol class="flex items-center gap-2 list-none"><li><a href="/" class="hover:text-primary-500">{t.brand}</a></li><li aria-hidden="true">›</li><li aria-current="page" class="text-zinc-700 dark:text-zinc-300">Kapcsolat</li></ol>
    </nav>
    <h1 class="mt-6 text-4xl md:text-5xl font-extrabold tracking-tight"><span class="gradient-text">Kapcsolat</span></h1>
    <p class="mt-4 text-lg text-zinc-700 dark:text-zinc-300">Visszajelzések, kérdések, együttműködés — szívesen várjuk!</p>

    <section class="mt-10 grid sm:grid-cols-2 gap-6">
      <div class="rounded-2xl border border-zinc-200 dark:border-white/10 p-6">
        <p class="text-xs uppercase tracking-widest text-zinc-500 font-semibold">📧 Email</p>
        <p class="mt-2 text-lg font-bold"><a href="mailto:bogarrenato@gmail.com" class="text-primary-500 underline">bogarrenato@gmail.com</a></p>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">Minden ügyben — visszajelzés, együttműködés, hibajelentés.</p>
      </div>
      <div class="rounded-2xl border border-zinc-200 dark:border-white/10 p-6">
        <p class="text-xs uppercase tracking-widest text-zinc-500 font-semibold">☕ Támogatás</p>
        <p class="mt-2 text-lg font-bold"><a href="https://ko-fi.com/bogarrenato" target="_blank" rel="noopener" class="text-primary-500 underline">ko-fi.com/bogarrenato</a></p>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">Egy kávé árával támogasd a fejlesztést.</p>
      </div>
      <div class="rounded-2xl border border-zinc-200 dark:border-white/10 p-6">
        <p class="text-xs uppercase tracking-widest text-zinc-500 font-semibold">🎵 TikTok</p>
        <p class="mt-2 text-lg font-bold"><a href="https://www.tiktok.com/@nvnaptrx" target="_blank" rel="noopener" class="text-primary-500 underline">@nvnaptrx</a></p>
      </div>
      <div class="rounded-2xl border border-zinc-200 dark:border-white/10 p-6">
        <p class="text-xs uppercase tracking-widest text-zinc-500 font-semibold">📷 Instagram</p>
        <p class="mt-2 text-lg font-bold"><a href="https://www.instagram.com/nevnaptarx" target="_blank" rel="noopener" class="text-primary-500 underline">@nevnaptarx</a></p>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold">Válaszadási idő</h2>
      <p class="mt-2 text-zinc-600 dark:text-zinc-400">Általában 1-3 munkanapon belül válaszolunk. Hétvégén és ünnepnapokon hosszabb is lehet.</p>
    </section>
  </article>
</BaseLayout>
