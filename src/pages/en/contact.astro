---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { strings } from '../../i18n/strings';
const t = strings.en;
---
<BaseLayout lang="en" title={`Contact | ${t.brand}`} description="Get in touch with the NévnapTárX developer." altLangPath="/contact">
  <article class="container mx-auto px-6 max-w-3xl pt-12 md:pt-16">
    <nav class="text-sm text-zinc-500" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 list-none"><li><a href="/en/" class="hover:text-primary-500">{t.brand}</a></li><li aria-hidden="true">›</li><li aria-current="page" class="text-zinc-700 dark:text-zinc-300">Contact</li></ol>
    </nav>
    <h1 class="mt-6 text-4xl md:text-5xl font-extrabold tracking-tight"><span class="gradient-text">Contact</span></h1>
    <p class="mt-4 text-lg text-zinc-700 dark:text-zinc-300">Feedback, questions, partnerships — we'd love to hear from you!</p>

    <section class="mt-10 grid sm:grid-cols-2 gap-6">
      <div class="rounded-2xl border border-zinc-200 dark:border-white/10 p-6">
        <p class="text-xs uppercase tracking-widest text-zinc-500 font-semibold">📧 Email</p>
        <p class="mt-2 text-lg font-bold"><a href="mailto:bogarrenato@gmail.com" class="text-primary-500 underline">bogarrenato@gmail.com</a></p>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">Anything — feedback, partnerships, bug reports.</p>
      </div>
      <div class="rounded-2xl border border-zinc-200 dark:border-white/10 p-6">
        <p class="text-xs uppercase tracking-widest text-zinc-500 font-semibold">☕ Support</p>
        <p class="mt-2 text-lg font-bold"><a href="https://ko-fi.com/bogarrenato" target="_blank" rel="noopener" class="text-primary-500 underline">ko-fi.com/bogarrenato</a></p>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">Buy me a coffee and support development.</p>
      </div>
      <div class="rounded-2xl border border-zinc-200 dark:border-white/10 p-6">
        <p class="text-xs uppercase tracking-widest text-zinc-500 font-semibold">🎵 TikTok</p>
        <p class="mt-2 text-lg font-bold"><a href="https://www.tiktok.com/@nvnaptrx" target="_blank" rel="noopener" class="text-primary-500 underline">@nvnaptrx</a></p>
      </div>
      <div class="rounded-2xl border border-zinc-200 dark:border-white/10 p-6">
        <p class="text-xs uppercase tracking-widest text-zinc-500 font-semibold">📷 Instagram</p>
        <p class="mt-2 text-lg font-bold"><a href="https://www.instagram.com/nevnaptarx" target="_blank" rel="noopener" class="text-primary-500 underline">@nevnaptarx</a></p>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold">Response time</h2>
      <p class="mt-2 text-zinc-600 dark:text-zinc-400">Usually within 1-3 business days. Weekends and holidays may be longer.</p>
    </section>
  </article>
</BaseLayout>
