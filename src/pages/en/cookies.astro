---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { strings } from '../../i18n/strings';
const t = strings.en;
---
<BaseLayout lang="en" title={`Cookie Policy | ${t.brand}`} description="What cookies nevnap.app uses and how to manage them." altLangPath="/cookies">
  <article class="container mx-auto px-6 max-w-3xl pt-12 md:pt-16">
    <nav class="text-sm text-zinc-500" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 list-none"><li><a href="/en/" class="hover:text-primary-500">{t.brand}</a></li><li aria-hidden="true">›</li><li aria-current="page" class="text-zinc-700 dark:text-zinc-300">Cookie Policy</li></ol>
    </nav>
    <h1 class="mt-6 text-4xl md:text-5xl font-extrabold tracking-tight"><span class="gradient-text">Cookie Policy</span></h1>
    <p class="mt-2 text-sm text-zinc-500">Last updated: January 1, 2026.</p>

    <section class="mt-10 space-y-6 text-zinc-700 dark:text-zinc-300 leading-relaxed">
      <div>
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">What is a cookie?</h2>
        <p class="mt-2">A cookie is a small text file your browser stores from visited websites. Cookies help the site remember you, your settings, and create traffic statistics.</p>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">What cookies we use</h2>

        <div class="mt-4 rounded-2xl border border-zinc-200 dark:border-white/10 p-5">
          <h3 class="font-bold">🟢 Necessary (always active)</h3>
          <p class="mt-1 text-sm">Required for basic site functionality.</p>
          <table class="mt-3 w-full text-xs">
            <thead class="text-left text-zinc-500"><tr><th class="py-1 pr-3">Name</th><th class="py-1 pr-3">Purpose</th><th class="py-1">Lifespan</th></tr></thead>
            <tbody>
              <tr class="border-t border-zinc-200/60 dark:border-white/5"><td class="py-1 pr-3">nevnap-theme</td><td class="py-1 pr-3">Theme (dark/light)</td><td class="py-1">12 mo</td></tr>
              <tr class="border-t border-zinc-200/60 dark:border-white/5"><td class="py-1 pr-3">nevnap-consent</td><td class="py-1 pr-3">Cookie consent</td><td class="py-1">12 mo</td></tr>
            </tbody>
          </table>
        </div>

        <div class="mt-4 rounded-2xl border border-zinc-200 dark:border-white/10 p-5">
          <h3 class="font-bold">🔵 Analytics (with consent)</h3>
          <p class="mt-1 text-sm">Anonymous traffic statistics. Does not identify you personally.</p>
          <table class="mt-3 w-full text-xs">
            <thead class="text-left text-zinc-500"><tr><th class="py-1 pr-3">Name</th><th class="py-1 pr-3">Provider</th><th class="py-1">Lifespan</th></tr></thead>
            <tbody>
              <tr class="border-t border-zinc-200/60 dark:border-white/5"><td class="py-1 pr-3">_ga, _ga_*</td><td class="py-1 pr-3">Google Analytics 4</td><td class="py-1">14 mo</td></tr>
            </tbody>
          </table>
        </div>

        <div class="mt-4 rounded-2xl border border-zinc-200 dark:border-white/10 p-5">
          <h3 class="font-bold">🟠 Marketing (future, with consent)</h3>
          <p class="mt-1 text-sm">For relevant ad display. <strong>Not active yet</strong>. We will update this policy before activation.</p>
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">Managing your cookie preferences</h2>
        <ul class="mt-2 list-disc list-inside space-y-1">
          <li><button type="button" id="reopen-banner" class="text-primary-500 underline">Reopen cookie banner</button></li>
          <li>Your browser settings</li>
          <li>Google Analytics opt-out: <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener" class="text-primary-500 underline">tools.google.com/dlpage/gaoptout</a></li>
        </ul>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">More info</h2>
        <p class="mt-2">See the full <a href="/en/privacy" class="text-primary-500 underline">Privacy Policy</a>.</p>
      </div>
    </section>
  </article>
  <script is:inline>
    document.getElementById('reopen-banner')?.addEventListener('click', function () {
      if (window.nevnapConsent?.reopen) window.nevnapConsent.reopen();
    });
  </script>
</BaseLayout>
