---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { strings, interpolate, SITE_URL } from '../../i18n/strings';
import { getCollection, render } from 'astro:content';
import { SEO_IDS, buildBreadcrumbSchema, buildWebPageSchema } from '../../lib/seo';

export async function getStaticPaths() {
  const all = await getCollection('blog', ({ data }) => data.lang === 'hu');
  return all.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const t = strings.hu;
const fmtDate = (d: Date) => `${d.getFullYear()}. ${t.months[d.getMonth()]} ${d.getDate()}.`;
const pagePath = `/blog/${post.id}`;

const jsonLd = [
  buildWebPageSchema({
    path: pagePath,
    name: post.data.title,
    description: post.data.description,
    mainEntity: { '@id': `${SITE_URL}${pagePath}#article` },
  }),
  buildBreadcrumbSchema([
    { name: t.brand, path: '/' },
    { name: t.blog.title, path: '/blog' },
    { name: post.data.title, path: pagePath },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    '@id': `${SITE_URL}${pagePath}#article`,
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: post.data.pubDate.toISOString(),
    inLanguage: 'hu-HU',
    isAccessibleForFree: true,
    author: { '@id': SEO_IDS.creator },
    publisher: { '@id': SEO_IDS.organization },
    image: `${SITE_URL}/og-default.png`,
    mainEntityOfPage: { '@id': `${SITE_URL}${pagePath}#webpage` },
    keywords: post.data.tags,
  },
];
---
<BaseLayout lang="hu" title={`${post.data.title} | ${t.brand}`} description={post.data.description} jsonLd={jsonLd}>
  <article class="container mx-auto px-6 max-w-3xl pt-12 md:pt-16">
    <nav class="text-sm text-zinc-500" aria-label="Morzsamenü">
      <ol class="flex items-center gap-2 list-none">
        <li><a href="/" class="hover:text-primary-500">{t.brand}</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/blog" class="hover:text-primary-500">{t.blog.title}</a></li>
        <li aria-hidden="true">›</li>
        <li aria-current="page" class="text-zinc-700 dark:text-zinc-300 truncate">{post.data.title}</li>
      </ol>
    </nav>

    <header class="mt-8">
      <div class="flex items-center gap-3 text-xs text-zinc-500">
        <time datetime={post.data.pubDate.toISOString()}>{fmtDate(post.data.pubDate)}</time>
        <span aria-hidden="true">•</span>
        <span>{interpolate(t.blog.readingTime, { min: String(post.data.readingMinutes) })}</span>
      </div>
      <h1 class="mt-4 text-4xl md:text-5xl font-extrabold tracking-tight leading-tight">{post.data.title}</h1>
      <p class="mt-4 text-lg text-zinc-600 dark:text-zinc-400 leading-relaxed">{post.data.description}</p>

      {post.data.tags.length > 0 && (
        <ul class="mt-5 flex flex-wrap gap-2 list-none">
          {post.data.tags.map((tag: string) => (
            <li>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-zinc-100 dark:bg-white/10 text-xs">#{tag}</span>
            </li>
          ))}
        </ul>
      )}
    </header>

    <div class="blog-content mt-10">
      <Content />
    </div>

    <footer class="mt-16 pt-8 border-t border-zinc-200 dark:border-white/10">
      <a href="/blog" class="text-primary-500 hover:underline font-semibold">{t.blog.backToBlog}</a>
    </footer>
  </article>
</BaseLayout>
