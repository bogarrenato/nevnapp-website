---
/**
 * Calendar index page — shows every month with the primary nameday on each day.
 * SEO target: "magyar névnaptár", "{hónap} névnapok".
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { strings } from '../i18n/strings';
import { getEntryByDate, dateKey } from '../lib/names';

const t = strings.hu;

const months = Array.from({ length: 12 }, (_, m) => {
  const monthIndex = m + 1;
  const daysInMonth = new Date(2024, monthIndex, 0).getDate();
  return {
    index: monthIndex,
    label: t.months[m],
    days: Array.from({ length: daysInMonth }, (_, d) => {
      const day = d + 1;
      const entry = getEntryByDate(monthIndex, day);
      return { day, primary: entry?.primary ?? [], dateKey: dateKey(monthIndex, day) };
    }),
  };
});

const title = `Magyar névnaptár 2026 — minden névnap egy helyen | ${t.brand}`;
const description = '2026 teljes magyar névnap-naptára: minden hónapban minden napra eső név, közvetlen linkkel a részletes oldalra.';
---

<BaseLayout lang="hu" title={title} description={description} altLangPath="/naptar">
  <section class="container mx-auto px-6 pt-12 md:pt-16">
    <header class="max-w-3xl">
      <p class="text-sm uppercase tracking-widest font-semibold text-primary-600 dark:text-primary-400">2026</p>
      <h1 class="mt-2 text-5xl md:text-6xl font-extrabold tracking-tight">
        <span class="gradient-text">Magyar névnaptár</span>
      </h1>
      <p class="mt-3 text-zinc-600 dark:text-zinc-400 text-lg">
        Minden napra a hivatalos magyar névnap — koppints egy névre a részletekért.
      </p>
    </header>

    <div class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {months.map((m) => (
        <article class="glass rounded-3xl p-6" aria-labelledby={`month-${m.index}-heading`}>
          <h2 id={`month-${m.index}-heading`} class="text-2xl font-extrabold tracking-tight gradient-text">{m.label}</h2>
          <ul class="mt-4 space-y-1.5 text-sm list-none">
            {m.days.map((d) => (
              <li class="flex items-baseline justify-between gap-2">
                <a
                  href={`/napi/${d.dateKey}`}
                  class="tabular-nums text-zinc-500 hover:text-primary-500 transition w-8 shrink-0"
                  aria-label={`${m.label} ${d.day}. — napi névnap részletek`}
                >
                  {d.day}.
                </a>
                <span class="text-right flex-1 truncate">
                  {d.primary.length ? d.primary.map((n, i) => (
                    <>
                      <a href={`/nev/${encodeURIComponent(n)}`} class="hover:text-primary-500 transition font-medium">{n}</a>
                      {i < d.primary.length - 1 && <span aria-hidden="true">, </span>}
                    </>
                  )) : (
                    <span class="text-zinc-400 dark:text-zinc-600" aria-label="Nincs névnap">—</span>
                  )}
                </span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
