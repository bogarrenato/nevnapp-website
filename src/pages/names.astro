---
/**
 * All-names index page. Lists every name grouped by initial letter,
 * each linking to /name/[name]. SEO-rich (lots of internal links).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { strings, interpolate } from '../i18n/strings';
import { getAllNames, normalize } from '../lib/names';
import {
  SEO_IDS,
  buildBreadcrumbSchema,
  buildDefinedTermSetSchema,
  buildNamedayDatasetSchema,
  buildWebPageSchema,
} from '../lib/seo';

const t = strings.hu;
const names = getAllNames();

const groups = new Map<string, string[]>();
for (const name of names) {
  const letter = normalize(name)[0].toUpperCase();
  if (!groups.has(letter)) groups.set(letter, []);
  groups.get(letter)!.push(name);
}
const letters = Array.from(groups.keys()).sort((a, b) => a.localeCompare(b, 'hu'));

const title = `${interpolate(t.namesPage.title, { count: String(names.length) })} | ${t.brand}`;
const description = interpolate(t.namesPage.description, { count: String(names.length) });

const jsonLd = [
  buildWebPageSchema({
    path: '/names',
    name: title,
    description,
    type: 'CollectionPage',
    mainEntity: { '@id': SEO_IDS.nameTermSet },
    about: { '@id': SEO_IDS.namedayDataset },
  }),
  buildBreadcrumbSchema([
    { name: t.brand, path: '/' },
    { name: t.namesPage.heading, path: '/names' },
  ]),
  buildNamedayDatasetSchema(names.length),
  buildDefinedTermSetSchema(names.length),
];
---

<BaseLayout lang="hu" title={title} description={description} jsonLd={jsonLd}>
  <section class="container mx-auto px-6 pt-12 md:pt-16">
    <header class="max-w-3xl">
      <p class="text-sm uppercase tracking-widest font-semibold text-primary-600 dark:text-primary-400">Névszótár</p>
      <h1 class="mt-2 text-5xl md:text-6xl font-extrabold tracking-tight">
        <span class="gradient-text">{t.namesPage.heading}</span>
      </h1>
      <p class="mt-3 text-zinc-600 dark:text-zinc-400 text-lg">
        {interpolate(t.namesPage.subtitle, { count: String(names.length) })}
      </p>
    </header>

    <section class="mt-8 rounded-2xl border border-primary-500/20 bg-primary-50/70 dark:bg-primary-500/10 p-5 max-w-3xl" aria-labelledby="names-summary-heading">
      <h2 id="names-summary-heading" class="text-sm uppercase tracking-widest font-semibold text-primary-700 dark:text-primary-300">
        Adatbázis összefoglaló
      </h2>
      <p class="mt-3 text-zinc-700 dark:text-zinc-300 leading-relaxed">
        A NévnapTárX névszótára {names.length} magyar keresztnevet rendez A-tól Z-ig. A névoldalak névnap-dátumot, névjelentést és névnapi köszöntőket tartalmaznak, így a lista belső térképként szolgál a teljes magyar névnap-adatbázishoz.
      </p>
    </section>

    <nav
      class="mt-8 flex flex-wrap gap-1.5 sticky top-16 bg-white/70 dark:bg-zinc-950/70 backdrop-blur-xl py-3 z-30 -mx-2 px-2 rounded-2xl"
      aria-label="Ugrás betű szerint"
    >
      <ul class="flex flex-wrap gap-1.5 list-none">
        {letters.map((l) => (
          <li>
            <a
              href={`#letter-${l}`}
              class="size-9 grid place-items-center rounded-full text-sm font-bold hover:bg-primary-100 dark:hover:bg-primary-500/20 hover:text-primary-700 dark:hover:text-primary-300 transition"
              aria-label={`Ugrás a ${l} betűs nevekre`}
            >
              {l}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="mt-12 space-y-10">
      {letters.map((l) => (
        <section id={`letter-${l}`} aria-labelledby={`letter-${l}-heading`}>
          <h2 id={`letter-${l}-heading`} class="text-3xl md:text-4xl font-extrabold tracking-tight gradient-text">{l}</h2>
          <ul class="mt-4 flex flex-wrap gap-2 list-none">
            {groups.get(l)!.map((name) => (
              <li>
                <a
                  href={`/name/${encodeURIComponent(name)}`}
                  class="px-3 py-1.5 rounded-full bg-zinc-100 dark:bg-white/10 hover:bg-gradient-to-r hover:from-primary-500 hover:to-violet-500 hover:text-white transition text-sm font-medium"
                >
                  {name}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
