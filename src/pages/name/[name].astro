---
/**
 * Dynamic route — one SEO-optimized page per Hungarian first name.
 * URL: /name/Anna  /name/Mirkó  /name/Eszter ...
 *
 * Build-time generated. ~1500 pages total. Each one targets the long-tail
 * query "{name} névnap" + "{name} név jelentése" + brand searches.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { strings, SITE_URL, interpolate } from '../../i18n/strings';
import { STORE_LINKS } from '../../lib/constants';
import DownloadDropdown from '../../components/DownloadDropdown.astro';
import {
  getAllNames,
  getDatesForName,
  getMeaning,
  getRelatedNames,
  isPrimary,
} from '../../lib/names';

export function getStaticPaths() {
  return getAllNames().map((name) => ({
    params: { name },
    props: { name },
  }));
}

const { name } = Astro.props as { name: string };
const t = strings.hu;
const dates = getDatesForName(name);
const meaning = getMeaning(name);
const related = getRelatedNames(name);

const datesLabel = dates
  .map((e) => `${t.monthsShort[e.month - 1]} ${e.day}.`)
  .join(', ');

const title = `${name} névnap, jelentése${datesLabel ? ` — ${datesLabel}` : ''} | ${t.brand}`;
const description = meaning
  ? `A ${name} név jelentése, eredete és magyar névnapjai. ${meaning.slice(0, 130)}…`
  : `Mikor van ${name} névnapja? Eredet, jelentés és modern névnap-naptár app a NévnapTárX-tól.`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: t.brand, item: SITE_URL },
      { '@type': 'ListItem', position: 2, name: t.namePage.breadcrumbNames, item: `${SITE_URL}/names` },
      { '@type': 'ListItem', position: 3, name },
    ],
  },
  meaning ? {
    '@context': 'https://schema.org',
    '@type': 'DefinedTerm',
    name,
    description: meaning,
    inDefinedTermSet: { '@type': 'DefinedTermSet', name: 'Magyar keresztnevek' },
  } : null,
  dates.length ? {
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: `${name} névnapja`,
    description: meaning ?? `${name} névnapja a magyar naptár szerint.`,
    startDate: `2026-${String(dates[0].month).padStart(2, '0')}-${String(dates[0].day).padStart(2, '0')}`,
    eventSchedule: dates.map((d) => ({
      '@type': 'Schedule',
      byMonth: d.month,
      byMonthDay: d.day,
      repeatFrequency: 'P1Y',
    })),
  } : null,
].filter(Boolean) as object[];
---

<BaseLayout
  lang="hu"
  title={title}
  description={description}
  altLangPath={`/name/${encodeURIComponent(name)}`}
  jsonLd={jsonLd}
>
  <article class="container mx-auto px-6 max-w-3xl pt-12 md:pt-16">
    <nav class="text-sm text-zinc-500" aria-label={t.namePage.breadcrumbAria}>
      <ol class="flex items-center gap-2 list-none">
        <li><a href="/" class="hover:text-primary-500">{t.brand}</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/names" class="hover:text-primary-500">{t.namePage.breadcrumbNames}</a></li>
        <li aria-hidden="true">›</li>
        <li aria-current="page" class="text-zinc-700 dark:text-zinc-300">{name}</li>
      </ol>
    </nav>

    <header class="mt-6">
      <p class="text-sm uppercase tracking-widest font-semibold text-primary-600 dark:text-primary-400">{t.namePage.eyebrow}</p>
      <h1 class="mt-2 text-5xl md:text-6xl font-extrabold tracking-tight">
        <span class="gradient-text">{name}</span>
      </h1>
      <p class="mt-3 text-zinc-600 dark:text-zinc-400 text-lg">
        {interpolate(t.namePage.heading, { name })}
      </p>
    </header>

    <section class="mt-10 glass rounded-3xl p-6 md:p-8" aria-labelledby="dates-heading">
      <h2 id="dates-heading" class="text-xs uppercase tracking-widest font-semibold text-zinc-500 dark:text-zinc-400">
        {interpolate(t.namePage.datesHeading, { name })}
      </h2>
      {dates.length ? (
        <ul class="mt-4 flex flex-wrap gap-2 list-none">
          {dates.map((d) => {
            const dayPadded = String(d.day).padStart(2, '0');
            const monthPadded = String(d.month).padStart(2, '0');
            const dateLabel = `${t.months[d.month - 1]} ${d.day}.`;
            return (
              <li>
                <a
                  href={`/day/${monthPadded}-${dayPadded}`}
                  class:list={[
                    'inline-flex items-center gap-2 px-4 py-2 rounded-full font-semibold transition',
                    isPrimary(name, d)
                      ? 'bg-gradient-to-r from-primary-500 to-violet-500 text-white shadow-lg shadow-primary-500/30'
                      : 'bg-zinc-100 dark:bg-white/10 hover:bg-zinc-200 dark:hover:bg-white/15',
                  ]}
                >
                  <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                    <path d="M19 4h-2V2h-2v2H9V2H7v2H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z"/>
                  </svg>
                  <time datetime={`--${monthPadded}-${dayPadded}`}>{dateLabel}</time>
                </a>
              </li>
            );
          })}
        </ul>
      ) : (
        <p class="mt-3 text-zinc-600 dark:text-zinc-400">{t.namePage.noDates}</p>
      )}
    </section>

    <section class="mt-8" aria-labelledby="meaning-heading">
      <h2 id="meaning-heading" class="text-2xl md:text-3xl font-extrabold tracking-tight">
        {interpolate(t.namePage.meaningHeading, { name })}
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-zinc-700 dark:text-zinc-300" lang="hu">
        {meaning ?? interpolate(t.namePage.noMeaning, { name })}
      </p>
    </section>

    <aside class="mt-12">
      <DownloadDropdown
        lang="hu"
        variant="cta"
        id={`name-greeting-${name}`}
        label={interpolate(t.namePage.sendGreeting, { name })}
      />
    </aside>

    {related.length > 0 && (
      <section class="mt-16" aria-labelledby="related-heading">
        <h2 id="related-heading" class="text-xl md:text-2xl font-extrabold tracking-tight">{t.namePage.relatedHeading}</h2>
        <ul class="mt-4 flex flex-wrap gap-2 list-none">
          {related.map((r) => (
            <li>
              <a
                href={`/name/${encodeURIComponent(r)}`}
                class="px-4 py-2 rounded-full bg-zinc-100 dark:bg-white/10 hover:bg-primary-100 dark:hover:bg-primary-500/20 hover:text-primary-700 dark:hover:text-primary-300 transition text-sm font-medium"
              >
                {r}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
